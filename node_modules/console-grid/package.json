{
    "name": "console-grid",
    "version": "2.2.4",
    "description": "A lightweight, zero-dependency utility for rendering formatted grids/tables in the Node.js console",
    "main": "./lib/index.js",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "import": "./lib/index.mjs",
            "require": "./lib/index.js",
            "default": "./lib/index.js"
        },
        "./package.json": "./package.json"
    },
    "types": "./lib/index.d.ts",
    "scripts": {
        "link": "sf link ./ -f",
        "build": "node ./scripts/build.mjs",
        "test": "node ./scripts/test.mjs",
        "patch": "npm run test && npm run build && sf publish patch -r"
    },
    "files": [
        "lib"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cenfun/console-grid.git"
    },
    "dependencies": {},
    "devDependencies": {
        "chalk": "^5.6.2",
        "eastasianwidth": "^0.3.0",
        "eight-colors": "^1.3.3",
        "eslint": "^10.2.0",
        "eslint-config-plus": "^2.0.4",
        "js-beautify": "^1.15.4",
        "papaparse": "^5.5.3"
    }
}
