{
    "name": "monocart-locator",
    "version": "1.0.3",
    "description": "A lightweight source code position locator for converting between offset and line/column, with built-in line and comment parsing",
    "main": "./lib/index.js",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "import": "./lib/index.mjs",
            "require": "./lib/index.js",
            "default": "./lib/index.js"
        },
        "./package.json": "./package.json"
    },
    "types": "./lib/index.d.ts",
    "scripts": {
        "test": "mocha",
        "patch": "npm run test && sf publish patch"
    },
    "files": [
        "lib"
    ],
    "keywords": [
        "locator",
        "source",
        "position",
        "offset",
        "line",
        "column",
        "comment",
        "parser"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cenfun/monocart-locator.git"
    },
    "dependencies": {},
    "devDependencies": {
        "console-grid": "^2.2.4",
        "eight-colors": "^1.3.3",
        "eslint": "^10.2.0",
        "eslint-config-plus": "^2.0.4",
        "mocha": "^11.7.5"
    }
}
